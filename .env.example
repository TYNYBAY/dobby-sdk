# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- Option A: Direct Anthropic API ---
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Option B: Azure AI Foundry (Claude on Azure) ---
# Uses AsyncAnthropicFoundry — sends correct "api-key" auth header automatically.
# RESOURCE and BASE_URL are mutually exclusive — set only one.
#
# Find your key + resource: Azure Portal → your AI Foundry resource → Keys and Endpoint
# The resource name is the subdomain: https://<RESOURCE>.services.ai.azure.com/

# Azure API key (from Azure Portal → Keys and Endpoint → Key 1 or Key 2)
ANTHROPIC_FOUNDRY_API_KEY=...

# Option B1 (preferred): resource name only — SDK builds the URL automatically
#   Result: https://<resource>.services.ai.azure.com/anthropic/v1/messages
ANTHROPIC_FOUNDRY_RESOURCE=my-resource

# Option B2: full base URL — use ONLY if B1 doesn't work
#   Must end with /anthropic/ (include trailing slash)
ANTHROPIC_FOUNDRY_BASE_URL=https://my-resource.services.ai.azure.com/anthropic/

# Azure deployment name (shown in Azure AI Foundry → Deployments)
ANTHROPIC_FOUNDRY_MODEL=claude-sonnet-4-5

# --- Optional: Tavily API key (web search tests only) ---
# Get yours at https://tavily.com/
TAVILY_API_KEY=tvly-...
