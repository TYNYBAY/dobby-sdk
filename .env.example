# Copy this file to .env and fill in your keys
# cp .env.example .env

# =============================================================================
# CLAUDE SONNET — Azure AI Foundry deployment
# Azure Portal → your Sonnet resource → Keys and Endpoint
# =============================================================================

ANTHROPIC_SONNET_FOUNDRY_API_KEY=...
ANTHROPIC_SONNET_FOUNDRY_RESOURCE=my-sonnet-resource
# ANTHROPIC_SONNET_FOUNDRY_BASE_URL=https://my-sonnet-resource.services.ai.azure.com/anthropic/
ANTHROPIC_SONNET_FOUNDRY_MODEL=claude-sonnet-4-6

# =============================================================================
# CLAUDE HAIKU — Azure AI Foundry deployment (separate resource)
# Azure Portal → your Haiku resource → Keys and Endpoint
# =============================================================================

ANTHROPIC_HAIKU_FOUNDRY_API_KEY=...
ANTHROPIC_HAIKU_FOUNDRY_RESOURCE=my-haiku-resource
# ANTHROPIC_HAIKU_FOUNDRY_BASE_URL=https://my-haiku-resource.services.ai.azure.com/anthropic/
ANTHROPIC_HAIKU_FOUNDRY_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# GPT — Azure OpenAI deployment
# Azure Portal → your Azure OpenAI resource → Keys and Endpoint
# base_url format: https://<resource>.openai.azure.com/
# =============================================================================

OPENAI_AZURE_API_KEY=...
OPENAI_AZURE_BASE_URL=https://my-openai-resource.openai.azure.com/
OPENAI_AZURE_DEPLOYMENT_ID=gpt-4o
# OPENAI_AZURE_API_VERSION=2025-03-01-preview

# =============================================================================
# FALLBACK — direct Anthropic API (used only if Azure vars not set)
# =============================================================================

ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPTIONAL
# =============================================================================

# Tavily (web search tests)
TAVILY_API_KEY=tvly-...
