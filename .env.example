# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- Option A: Direct Anthropic API ---
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Option B: Azure AI Foundry (Claude on Azure) ---
# Read automatically by AsyncAnthropicFoundry when not passed as constructor args.
# Provide either RESOURCE or BASE_URL (not both).

# Azure API key (from Azure AI Foundry resource)
ANTHROPIC_FOUNDRY_API_KEY=...

# Option B1: Azure resource name  →  SDK builds https://<resource>.services.ai.azure.com/anthropic/
ANTHROPIC_FOUNDRY_RESOURCE=my-resource

# Option B2: Full Azure endpoint URL (use instead of RESOURCE)
ANTHROPIC_FOUNDRY_BASE_URL=https://my-resource.services.ai.azure.com/anthropic/

# Azure deployment/model name
ANTHROPIC_FOUNDRY_MODEL=claude-sonnet-4-6

# --- Optional: Tavily API key (web search tests only) ---
# Get yours at https://tavily.com/
TAVILY_API_KEY=tvly-...
